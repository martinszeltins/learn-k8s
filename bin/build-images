#!/bin/sh
set -e

cd "$(dirname "$0")/.."

echo "Building server image..."
docker build -t learn-k8s-server:latest -f docker/images/server/Dockerfile.prod .

echo "Building client image..."
docker build -t learn-k8s-client:latest -f docker/images/client/Dockerfile.prod .

echo "Done! Images built:"
docker images | grep learn-k8s
